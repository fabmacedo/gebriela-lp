Options -Indexes

ErrorDocument 404 /aprova/404.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^(backup|config|includes|scripts)(/|$) - [F,L]
    RewriteRule ^(database\.sql|docker-compose\.yml|Dockerfile|gabriela-site\.zip)$ - [F,L]
</IfModule>

<Files "database.sql">
    Require all denied
</Files>

<FilesMatch "(^\.|\.env|\.ini|\.log|\.sql|\.bak|\.config|\.zip|composer\.(json|lock)|package(-lock)?\.json|Dockerfile|docker-compose\.yml)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
